    "@types/pg": "^8.11.10",
    "argon2": "^0.43.0",
    "drizzle-kit": "^0.30.4",
    "drizzle-orm": "0.45.2",
    "elysia": "^1.2.25",
    "ioredis": "^5.6.0",
    "jose": "^6.2.2",
    "nanoid": "^5.1.5",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
