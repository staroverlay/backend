# Server configuration
PORT=3000
NODE_ENV=development

# Database and Redis
DATABASE_URL=postgresql://user:password@localhost:5432/staroverlay
REDIS_URL=redis://localhost:6379

# JWT settings
# Generate secrets with: openssl rand -base64 32
JWT_ACCESS_SECRET=your_32_characters_secret_at_least_access
JWT_REFRESH_SECRET=your_32_characters_secret_at_least_refresh
JWT_ACCESS_EXPIRES_MIN=10
JWT_REFRESH_EXPIRES_DAYS=30
JWT_REFRESH_GRACE_MINUTES=3

# SMTP (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@gmail.com
SMTP_PASS=app_password_here
EMAIL_FROM=noreply@staroverlay.com

# Frontend and App URL
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
APP_WIDGET_SERVER=http://localhost:4000

# OAuth - Twitch (Optional)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/oauth/callback/twitch

# OAuth - Kick (Optional)
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=http://localhost:3000/oauth/callback/kick

# OAuth - Google (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback/google
